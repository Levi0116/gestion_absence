# .env.example
# Copiez ce fichier en .env et modifiez les valeurs selon votre configuration

# Clé secrète pour Flask (changez-la en production !)
SECRET_KEY=votre-cle-secrete-tres-longue-et-complexe

# Configuration MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=votre_mot_de_passe
MYSQL_DATABASE=gestion_absences

# Environnement Flask
FLASK_ENV=development
FLASK_DEBUG=True